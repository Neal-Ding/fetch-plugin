{
  "name": "fetch-plugin",
  "version": "1.3.0",
  "description": "fetch polyfill with TIMEOUT setting and JSONP, extend from whatwg-fetch",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "debug": "node --nolazy --inspect-brk=5858 ./test/main.js",
    "test": "node ./test/main.js && nyc report --reporter=lcov --reporter=html",
    "build": "rollup --config build/rollup.config.mjs",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neal-Ding/fetch-plugin.git"
  },
  "keywords": [
    "fetch",
    "timeout"
  ],
  "author": "Neal-Ding",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Neal-Ding/fetch-plugin/issues"
  },
  "homepage": "https://github.com/Neal-Ding/fetch-plugin#readme",
  "dependencies": {
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-plugin-istanbul": "^6.1.1",
    "chai": "^5.1.0",
    "json-server": "^0.17.4",
    "mocha": "^11.0.0",
    "nyc": "^17.0.0",
    "puppeteer": "^23.0.0",
    "puppeteer-to-istanbul": "^1.4.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.24.0"
  }
}
